{
  "name": "learnverse",
  "version": "0.1.0",
  "private": true,
  "description": "LearnVerse LearnVerse - Multi-subject learning platform for children",
  "workspaces": [
    "packages/services/*",
    "packages/platform-contracts",
    "packages/platform-web/*",
    "packages/platform-mobile/app",
    "packages/platform-mobile/audio",
    "packages/platform-mobile/camera",
    "packages/platform-mobile/filesystem",
    "packages/platform-mobile/notifications",
    "packages/platform-mobile/ui",
    "infra/cdk"
  ],
  "scripts": {
    "build": "npx turbo build",
    "typecheck": "npx turbo typecheck",
    "lint": "npx turbo lint",
    "test:unit": "npx turbo test:unit",
    "test:property": "npx turbo test:property",
    "test:integration": "npx turbo test:integration",
    "test": "npx turbo test:unit test:property",
    "test:watch": "vitest",
    "build:user-guide": "npx tsx scripts/build-user-guide.ts",
    "validate:naming": "npx tsx scripts/validate-naming.ts",
    "validate:boundaries": "npx tsx scripts/validate-boundaries.ts",
    "validate": "npm run validate:naming && npm run validate:boundaries",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "fast-check": "3.22.0",
    "happy-dom": "^20.9.0",
    "marked": "14.1.4",
    "turbo": "^2.9.16",
    "typescript": "5.6.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=18.0.0"
  }
}
